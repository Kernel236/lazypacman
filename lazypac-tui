# Prompt user for a package name via dialog inputbox.
# Returns 1 (and prints nothing) if user cancels.
get_input() {
    local title="$1"
    local prompt="$2"
    local result
    exec 3>&1
    result=$(dialog \
        --backtitle "$BACKTITLE" \
        --output-fd 3 \
        --title " $title " \
        --inputbox "$prompt" 8 55 \
        2>/dev/null) || { exec 3>&-; return 1; }
    exec 3>&-
    echo "$result"
}

# Clear screen, print a minimal header, run lazypac, wait for ENTER.
# Interactive commands (upgrade, etc.) work correctly because output
# goes directly to the terminal, not captured into a dialog box.
run_cmd() {
    tput clear
    echo -e "  \e[1;33mlazypac-tui\e[0m  \e[90m‚ĒÄ‚ĒÄ  running:\e[0m lazypac $*"
    echo -e "  \e[90m$(printf '‚ĒÄ%.0s' {1..60})\e[0m"
    echo ""
    lazypac "$@" || true
    echo ""
    echo -e "  \e[90mPress ENTER to return to menu...\e[0m"
    read -r
}

# ---------------------------------------------------------------------------
# Submenus
# ---------------------------------------------------------------------------

menu_packages() {
    while true; do
        local choice
        exec 3>&1
        choice=$(dialog \
            --backtitle "$BACKTITLE" \
            --output-fd 3 \
            --title " Packages " \
            --cancel-label "Back" \
            --menu "Select a command:" 18 62 8 \
            "install"      "Install a package" \
            "remove"       "Remove a package" \
            "purge"        "Remove package and its dependencies" \
            "update"       "Sync package databases" \
            "upgrade"      "Full system upgrade" \
            "safe-upgrade" "Upgrade, skip packages with conflicts" \
            "downgrade"    "Downgrade a package" \
            2>/dev/null) || return
        exec 3>&-
        case "$choice" in
            install|remove|purge|downgrade)
                local pkg
                pkg=$(get_input "$choice" "Package name:") || continue
                [[ -z "$pkg" ]] && continue
                run_cmd "$choice" "$pkg"
                ;;
            *)
                run_cmd "$choice"
                ;;
        esac
    done
}

