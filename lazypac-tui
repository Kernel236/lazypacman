#!/usr/bin/env bash
set -euo pipefail

VERSION="1.3.0"
AUTHOR="Kernel236"
GITHUB_URL="github.com/Kernel236/lazypacman"
BACKTITLE="lazypac-tui  |  $AUTHOR  |  ★ $GITHUB_URL"

# Resolve the directory where this script lives, for finding assets at runtime.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------

check_deps() {
    if ! command -v dialog &>/dev/null; then
        echo "Error: 'dialog' is required but not installed."
        echo "Install it with: lazypac install dialog"
        exit 1
    fi
    if ! command -v lazypac &>/dev/null; then
        echo "Error: 'lazypac' is not in PATH."
        echo "Install lazypac first: https://$GITHUB_URL"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------

show_banner() {
    # Look for the banner script: repo-relative first, then installed path.
    local banner=""
    if [[ -f "$SCRIPT_DIR/assets/lazypacman_tui_banner.sh" ]]; then
        banner="$SCRIPT_DIR/assets/lazypacman_tui_banner.sh"
    elif [[ -f "/usr/lib/lazypac/tui_banner.sh" ]]; then
        banner="/usr/lib/lazypac/tui_banner.sh"
    fi

    if [[ -n "$banner" ]]; then
        # shellcheck source=assets/lazypacman_tui_banner.sh
        source "$banner"
        display_ansi_art
    fi

    echo ""
    echo -e "                \e[1;33mᗧ\e[0m  \e[90m• • • • • • •\e[0m    \e[1;34m[ PARU ]\e[0m  \e[1;32m[ YAY ]\e[0m  \e[1;33m[ PACMAN ]\e[0m    \e[1;31mᗣ\e[0m  \e[1;36mᗣ\e[0m  \e[1;35mᗣ\e[0m"
    echo -e "                       \e[2mverbose wrapper for\e[0m \e[1;34mparu\e[0m, \e[1;32myay\e[0m \e[2mand\e[0m \e[1;33mpacman\e[0m"
    echo ""
    echo -e "  \e[90m$AUTHOR  •  ★ drop a star: $GITHUB_URL\e[0m"
}

show_splash() {
    tput clear
    show_banner
    echo ""
    echo -e "  \e[90mPress ENTER to continue...\e[0m"
    read -r
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Prompt for a package name. Returns 1 (silently) if user cancels.
# dialog writes its selection to stderr; 2>&1 1>/dev/tty captures it.
get_input() {
    local title="$1"
    local prompt="$2"
    dialog \
        --backtitle "$BACKTITLE" \
        --title " $title " \
        --inputbox "$prompt" 8 55 \
        2>&1 1>/dev/tty
}

# Clear screen, print a mini-header, run lazypac, wait for ENTER.
# Running in the raw terminal keeps interactive commands (upgrade etc.) working.
run_cmd() {
    tput clear
    echo -e "  \e[1;33mlazypac-tui\e[0m  \e[90m──  running:\e[0m lazypac $*"
    echo -e "  \e[90m$(printf '─%.0s' {1..60})\e[0m"
    echo ""
    lazypac "$@" || true
    echo ""
    echo -e "  \e[90mPress ENTER to return to menu...\e[0m"
    read -r
}

# ---------------------------------------------------------------------------
# Submenus
# ---------------------------------------------------------------------------

menu_packages() {
    while true; do
        local choice
        choice=$(dialog \
            --backtitle "$BACKTITLE" \
            --title " Packages " \
            --cancel-label "Back" \
            --menu "Select a command:" 18 62 8 \
            "install"      "Install a package" \
            "remove"       "Remove a package" \
            "purge"        "Remove package and its dependencies" \
            "update"       "Sync package databases" \
            "upgrade"      "Full system upgrade" \
            "safe-upgrade" "Upgrade, skip packages with conflicts" \
            "downgrade"    "Downgrade a package" \
            2>&1 1>/dev/tty) || return

        case "$choice" in
            install|remove|purge|downgrade)
                local pkg
                pkg=$(get_input "$choice" "Package name:") || continue
                [[ -z "$pkg" ]] && continue
                run_cmd "$choice" "$pkg"
                ;;
            *)
                run_cmd "$choice"
                ;;
        esac
    done
}

menu_query() {
    while true; do
        local choice
        choice=$(dialog \
            --backtitle "$BACKTITLE" \
            --title " Query " \
            --cancel-label "Back" \
            --menu "Select a command:" 22 62 10 \
            "search"        "Search for a package" \
            "info"          "Show package information" \
            "list"          "List all installed packages" \
            "installed"     "Check if a package is installed" \
            "check"         "Verify package integrity" \
            "deps"          "Show dependencies of a package" \
            "orphans"       "List orphaned packages" \
            "check-updates" "Check for available updates" \
            "ignore"        "Add a package to ignore list" \
            "unignore"      "Remove a package from ignore list" \
            2>&1 1>/dev/tty) || return

        case "$choice" in
            search|info|check|deps|ignore|unignore|installed)
                local pkg
                pkg=$(get_input "$choice" "Package name:") || continue
                [[ -z "$pkg" ]] && continue
                run_cmd "$choice" "$pkg"
                ;;
            *)
                run_cmd "$choice"
                ;;
        esac
    done
}

menu_maintenance() {
    while true; do
        local choice
        choice=$(dialog \
            --backtitle "$BACKTITLE" \
            --title " Maintenance " \
            --cancel-label "Back" \
            --menu "Select a command:" 15 62 5 \
            "remove-orphans"  "Remove all orphaned packages" \
            "cache-size"      "Show package cache size" \
            "cache-clean"     "Clean cache (keep 2 versions per pkg)" \
            "cache-clean-old" "Remove old package versions from cache" \
            "cache-clean-all" "Wipe entire package cache" \
            2>&1 1>/dev/tty) || return

        run_cmd "$choice"
    done
}

menu_logs() {
    while true; do
        local choice
        choice=$(dialog \
            --backtitle "$BACKTITLE" \
            --title " Logs & Pacnew " \
            --cancel-label "Back" \
            --menu "Select a command:" 13 62 3 \
            "log"      "Show pacman log" \
            "logclean" "Clean pacman log" \
            "pacnew"   "Handle .pacnew config files" \
            2>&1 1>/dev/tty) || return

        run_cmd "$choice"
    done
}

# ---------------------------------------------------------------------------
# Main menu
# ---------------------------------------------------------------------------

main_menu() {
    while true; do
        local choice
        choice=$(dialog \
            --backtitle "$BACKTITLE" \
            --title " lazypac-tui v$VERSION " \
            --cancel-label "Quit" \
            --menu "Select a category:" 14 58 4 \
            "1" "  Packages     install / remove / upgrade …" \
            "2" "  Query        search / info / orphans …" \
            "3" "  Maintenance  cache / orphan cleanup …" \
            "4" "  Logs         log / logclean / pacnew" \
            2>&1 1>/dev/tty) || break

        case "$choice" in
            1) menu_packages ;;
            2) menu_query ;;
            3) menu_maintenance ;;
            4) menu_logs ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

check_deps
show_splash
main_menu
tput clear
echo -e "\e[90m  lazypac-tui — bye.\e[0m"
echo ""
