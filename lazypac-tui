# ---------------------------------------------------------------------------
# Main menu
# ---------------------------------------------------------------------------

main_menu() {
    while true; do
        local choice
        exec 3>&1
        choice=$(dialog \
            --backtitle "$BACKTITLE" \
            --output-fd 3 \
            --title " lazypac-tui v$VERSION " \
            --cancel-label "Quit" \
            --menu "Select a category:" 14 58 4 \
            "1" "  Packages     install / remove / upgrade ‚Ä¶" \
            "2" "  Query        search / info / orphans ‚Ä¶" \
            "3" "  Maintenance  cache / orphan cleanup ‚Ä¶" \
            "4" "  Logs         log / logclean / pacnew" \
            2>/dev/null) || break
        exec 3>&-
        case "$choice" in
            1) menu_packages ;;
            2) menu_query ;;
            3) menu_maintenance ;;
            4) menu_logs ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

check_deps
show_splash
main_menu
tput clear
echo -e "\e[90m  lazypac-tui ‚ÄĒ bye.\e[0m"
