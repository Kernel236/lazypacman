#!/usr/bin/env bash
set -euo pipefail

VERSION="1.3.0"
AUTHOR="Kernel236"
GITHUB_URL="github.com/Kernel236/lazypacman"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------

check_deps() {
    if ! command -v lazypac &>/dev/null; then
        echo "Error: 'lazypac' is not in PATH."
        echo "Install lazypac first: yay -S lazypac or at https://$GITHUB_URL"
        exit 1
    fi
    if command -v yay &>/dev/null; then
        SESSION_PKG=yay
    elif command -v paru &>/dev/null; then
        SESSION_PKG=paru
    else
        SESSION_PKG=pacman
    fi
}

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------

show_banner() {
    local banner=""
    if [[ -f "$SCRIPT_DIR/assets/lazypacman_tui_banner.sh" ]]; then
        banner="$SCRIPT_DIR/assets/lazypacman_tui_banner.sh"
    elif [[ -f "/usr/lib/lazypac/tui_banner.sh" ]]; then
        banner="/usr/lib/lazypac/tui_banner.sh"
    fi
    [[ -n "$banner" ]] && source "$banner"

    echo ""
    echo -e "                \e[1;33mᗧ\e[0m  \e[90m• • • • • • •\e[0m    \e[1;34m[ PARU ]\e[0m  \e[1;32m[ YAY ]\e[0m  \e[1;33m[ PACMAN ]\e[0m    \e[1;31mᗣ\e[0m  \e[1;36mᗣ\e[0m  \e[1;35mᗣ\e[0m"
    echo -e "                           verbose wrapper for \e[1;34mparu\e[0m, \e[1;32myay\e[0m and \e[1;33mpacman\e[0m"
    echo ""
    echo ""
    printf "  \033[1;33m%-16s\033[0minstall  remove  purge  update  upgrade  safe-upgrade  downgrade\n" "packages"
    printf "  \033[1;33m%-16s\033[0mignore  unignore  ignored  check-updates\n"                         "upgrade ctrl"
    printf "  \033[1;33m%-16s\033[0msearch  info  list  installed  check  deps  orphans\n"              "query"
    printf "  \033[1;33m%-16s\033[0mremove-orphans  cache-size  cache-clean  cache-clean-old  cache-clean-all\n" "maintenance"
    printf "  \033[1;33m%-16s\033[0mlog  logclean  pacnew\n"                                            "logs & pacnew"
    echo ""
    echo -e "  \e[1;33m$AUTHOR  •  ★ drop a star: $GITHUB_URL\e[0m"
}

# ---------------------------------------------------------------------------
# Arrow-key menu picker
#
# Usage: _pick "Title" labels_var values_var result_var
#   labels_var : name of array with display strings
#   values_var : name of array with return values (same length)
#   result_var : name of variable to store the selection in
# Returns 0 on selection, 1 on q / ESC (go back).
# ---------------------------------------------------------------------------

_pick() {
    local title="$1"
    local -n _display="$2"
    local -n _dispatch="$3"
    local -n _output="$4"
    local item_count=${#_display[@]}
    local idx=0 k k2 k3
    local total=$(( item_count + 5 ))   # \n + title\n + sep\n + \n + items + hint

    _restore() { tput cnorm 2>/dev/null; stty echo 2>/dev/null; }
    trap _restore RETURN

    tput civis 2>/dev/null
    stty -echo 2>/dev/null

    _draw() {
        local i
        for ((i = 0; i < item_count; i++)); do
            if ((i == idx)); then
                printf "  \033[1;33m› %s\033[0m\n" "${_display[$i]}"
            else
                printf "  \033[2m%s\033[0m\n" "${_display[$i]}"
            fi
        done
        printf "\n"
        printf "  \033[1;33m↑↓ / j k   ENTER select   q back/exit\033[0m\n"
    }

    _paint() {
        printf "\n  \033[1;33m%s\033[0m\n  " "$title"
        printf '─%.0s' {1..45}
        printf "\n\n"
        _draw
    }

    # Move cursor up N lines then clear to end of screen, then repaint.
    # Using relative cursor movement instead of tput sc/rc avoids position
    # drift when the initial draw causes terminal scroll.
    _redraw() {
        printf "\033[%dA" "$total"
        printf "\033[J"
        _paint
    }

    _clear_menu() {
        printf "\033[%dA" "$total"
        printf "\033[J"
    }

    # Reserve space before drawing so the terminal scrolls now (if needed)
    # rather than mid-draw, keeping relative cursor movement reliable.
    local i
    for ((i = 0; i < total; i++)); do printf '\n'; done
    printf "\033[%dA" "$total"
    _paint

    while true; do
        IFS= read -rsn1 k

        case "$k" in
            $'\033')
                if IFS= read -rsn1 -t 0.1 k2 && [[ "$k2" == '[' ]]; then
                    IFS= read -rsn1 -t 0.1 k3
                    case "$k3" in
                        A) if ((idx > 0));            then idx=$((idx - 1)); fi ;;
                        B) if ((idx < item_count-1)); then idx=$((idx + 1)); fi ;;
                    esac
                else
                    _clear_menu
                    return 1
                fi
                ;;
            k) if ((idx > 0));            then idx=$((idx - 1)); fi ;;
            j) if ((idx < item_count-1)); then idx=$((idx + 1)); fi ;;
            '')
                _output="${_dispatch[$idx]}"
                _clear_menu
                return 0
                ;;
            q|Q)
                _clear_menu
                return 1
                ;;
        esac

        _redraw
    done
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_package() {
    local prompt="$1"
    local input
    printf "  \033[1;33m%s\033[0m \033[90mpackage name(s):\033[0m " "$prompt" >&2
    read -r input
    printf "%s" "$input"
}

run_cmd() {
    printf "\n  \033[90mrunning:\033[0m lazypac %s\n  " "$*"
    printf '─%.0s' {1..50}
    printf "\n\n"
    lazypac "$@" || true
    tput cnorm 2>/dev/null
    stty echo 2>/dev/null
    printf "\n  \033[1;33mPress ENTER to continue...\033[0m"
    read -r
    printf "\n"
}

# ---------------------------------------------------------------------------
# Submenus
# ---------------------------------------------------------------------------

menu_packages() {
    local labels=("install       install packages"
                  "remove        remove + orphan deps"
                  "purge         remove + config files"
                  "update        sync repositories"
                  "upgrade       upgrade all packages"
                  "safe-upgrade  upgrade + log + pacnew check"
                  "downgrade     install older cached version")
    local values=("install" "remove" "purge" "update" "upgrade" "safe-upgrade" "downgrade")
    local choice

    while true; do
        if ! _pick "Packages" labels values choice; then return; fi
        printf "\n"
        case "$choice" in
            install|remove|purge|downgrade)
                local input; local -a pkgs
                input=$(get_package "$choice")
                [[ -z "$input" ]] && continue
                read -ra pkgs <<< "$input"
                printf "\n"
                run_cmd "$choice" "${pkgs[@]}"
                ;;
            *)
                run_cmd "$choice"
                ;;
        esac
    done
}

menu_upgrade_ctrl() {
    local labels=("ignore          add to IgnorePkg"
                  "unignore        remove from IgnorePkg"
                  "ignored         list pinned packages"
                  "check-updates   list pending updates")
    local values=("ignore" "unignore" "ignored" "check-updates")
    local choice

    while true; do
        if ! _pick "Upgrade ctrl" labels values choice; then return; fi
        printf "\n"
        case "$choice" in
            ignore|unignore)
                local input; local -a pkgs
                input=$(get_package "$choice")
                [[ -z "$input" ]] && continue
                read -ra pkgs <<< "$input"
                printf "\n"
                run_cmd "$choice" "${pkgs[@]}"
                ;;
            *)
                run_cmd "$choice"
                ;;
        esac
    done
}

menu_query() {
    local labels=("search      search in repos"
                  "info        show package details"
                  "list        list installed (names)"
                  "installed   list installed (name + version)"
                  "check       check if installed"
                  "deps        show dependency tree"
                  "orphans     list orphan packages")
    local values=("search" "info" "list" "installed" "check" "deps" "orphans")
    local choice

    while true; do
        if ! _pick "Query" labels values choice; then return; fi
        printf "\n"
        case "$choice" in
            search|info|installed|check|deps)
                local input; local -a pkgs
                input=$(get_package "$choice")
                [[ -z "$input" ]] && continue
                read -ra pkgs <<< "$input"
                printf "\n"
                run_cmd "$choice" "${pkgs[@]}"
                ;;
            *)
                run_cmd "$choice"
                ;;
        esac
    done
}

menu_maintenance() {
    local labels=("remove-orphans    remove all orphan packages"
                  "cache-size        show cache disk usage"
                  "cache-clean       keep latest version only"
                  "cache-clean-old   remove uninstalled cache"
                  "cache-clean-all   wipe entire cache")
    local values=("remove-orphans" "cache-size" "cache-clean" "cache-clean-old" "cache-clean-all")
    local choice

    while true; do
        if ! _pick "Maintenance" labels values choice; then return; fi
        printf "\n"
        run_cmd "$choice"
    done
}

menu_logs() {
    local labels=("log           list upgrade logs"
                  "log <file>    open a log with less"
                  "logclean      delete all logs"
                  "pacnew        find .pacnew / .pacsave")
    local values=("log" "log-open" "logclean" "pacnew")
    local choice

    while true; do
        if ! _pick "Logs & Pacnew" labels values choice; then return; fi
        printf "\n"
        case "$choice" in
            log-open)
                run_cmd log
                local input
                printf "  \033[1;33mopen\033[0m \033[90mlog filename:\033[0m "
                read -r input
                [[ -z "$input" ]] && continue
                printf "\n"
                run_cmd log "$input"
                ;;
            *)
                run_cmd "$choice"
                ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Main menu
# ---------------------------------------------------------------------------

main_menu() {
    local labels=("Packages      install / remove / upgrade …"
                  "Upgrade ctrl  ignore / unignore / check-updates"
                  "Query         search / info / orphans …"
                  "Maintenance   cache / orphan cleanup …"
                  "Logs          log / logclean / pacnew")
    local values=("packages" "upgrade-ctrl" "query" "maintenance" "logs")
    local choice

    while true; do
        if ! _pick "lazypac-tui  v$VERSION" labels values choice; then
            printf "  \033[1;33mexit lazypac-tui?\033[0m \033[2m[y/N]\033[0m "
            local confirm
            read -r confirm
            [[ "${confirm,,}" == "y" ]] && break
            printf "\033[1A\033[J"
            continue
        fi

        case "$choice" in
            packages)     menu_packages ;;
            upgrade-ctrl) menu_upgrade_ctrl ;;
            query)        menu_query ;;
            maintenance)  menu_maintenance ;;
            logs)         menu_logs ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

check_deps
tput clear
show_banner
main_menu
printf "  \033[1;33m==> exit..\033[0m\n"
printf "  \033[1;33m==> Current session used: %s\033[0m\n" "$SESSION_PKG"
printf "  \033[1;33m==> Stay lazy. bye bye...\033[0m\n"
printf "\n"
echo -e "                \e[1;33mᗧ\e[0m  \e[90m• • • • • • •\e[0m    \e[1;34m[ PARU ]\e[0m  \e[1;32m[ YAY ]\e[0m  \e[1;33m[ PACMAN ]\e[0m    \e[90m• • • • • • •\e[0m    \e[1;31mᗣ\e[0m  \e[1;36mᗣ\e[0m  \e[1;35mᗣ\e[0m"
printf "\n\n"
