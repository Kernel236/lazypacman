#!/usr/bin/env bash
set -euo pipefail

VERSION="1.3.0"
AUTHOR="Kernel236"
GITHUB_URL="github.com/Kernel236/lazypacman"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------

check_deps() {
    if ! command -v lazypac &>/dev/null; then
        echo "Error: 'lazypac' is not in PATH."
        echo "Install lazypac first: yay -S lazypac or at https://$GITHUB_URL"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------

show_banner() {
    local banner=""
    if [[ -f "$SCRIPT_DIR/assets/lazypacman_tui_banner.sh" ]]; then
        banner="$SCRIPT_DIR/assets/lazypacman_tui_banner.sh"
    elif [[ -f "/usr/lib/lazypac/tui_banner.sh" ]]; then
        banner="/usr/lib/lazypac/tui_banner.sh"
    fi
    [[ -n "$banner" ]] && source "$banner"

    echo ""
    echo -e "                \e[1;33mᗧ\e[0m  \e[90m• • • • • • •\e[0m    \e[1;34m[ PARU ]\e[0m  \e[1;32m[ YAY ]\e[0m  \e[1;33m[ PACMAN ]\e[0m    \e[1;31mᗣ\e[0m  \e[1;36mᗣ\e[0m  \e[1;35mᗣ\e[0m"
    echo -e "                       \e[2mverbose wrapper for\e[0m \e[1;34mparu\e[0m, \e[1;32myay\e[0m \e[2mand\e[0m \e[1;33mpacman\e[0m"
    echo ""
    echo ""
    printf "  \033[90m%-16s\033[0m  install  remove  purge  update  upgrade  safe-upgrade  downgrade\n" "packages"
    printf "  \033[90m%-16s\033[0m  ignore  unignore  ignored\n"                                        "upgrade ctrl"
    printf "  \033[90m%-16s\033[0m  check-updates\n"                                                    "updates"
    printf "  \033[90m%-16s\033[0m  search  info  list  installed  check  deps  orphans\n"              "query"
    printf "  \033[90m%-16s\033[0m  remove-orphans  cache-size  cache-clean  cache-clean-old  cache-clean-all\n" "maintenance"
    printf "  \033[90m%-16s\033[0m  log  logclean  pacnew\n"                                            "logs & pacnew"
    echo ""
    echo -e "  \e[90m$AUTHOR  •  ★ drop a star: $GITHUB_URL\e[0m"
}

# ---------------------------------------------------------------------------
# Arrow-key menu picker
#
# Usage: _pick "Title" labels_var values_var result_var
#   labels_var : name of array with display strings
#   values_var : name of array with return values (same length)
#   result_var : name of variable to store the selection in
# Returns 0 on selection, 1 on q / ESC (go back).
# ---------------------------------------------------------------------------

_pick() {
    local title="$1"
    local -n _lbl="$2"
    local -n _val="$3"
    local -n _res="$4"
    local n=${#_lbl[@]}
    local idx=0 k k2 k3

    _restore() { tput cnorm 2>/dev/null; stty echo 2>/dev/null; }
    trap _restore RETURN

    tput civis 2>/dev/null
    stty -echo 2>/dev/null

    _draw() {
        local i
        for ((i = 0; i < n; i++)); do
            if ((i == idx)); then
                printf "  \033[1;33m›\033[0m \033[1m%s\033[0m\n" "${_lbl[$i]}"
            else
                printf "    \033[2m%s\033[0m\n" "${_lbl[$i]}"
            fi
        done
        printf "  \033[90m↑↓ / j k navigate   ENTER select   q back\033[0m\n"
    }

    printf "\n  \033[1;33m%s\033[0m\n  " "$title"
    printf '─%.0s' {1..45}
    printf "\n\n"
    _draw

    local draw_lines=$((n + 1))   # items + hint line

    while true; do
        tput cuu "$draw_lines"
        IFS= read -rsn1 k

        case "$k" in
            $'\x1b')
                # Could be arrow key (\e[A/B) or standalone ESC
                if IFS= read -rsn1 -t 0.1 k2 && [[ "$k2" == '[' ]]; then
                    IFS= read -rsn1 -t 0.1 k3
                    case "$k3" in
                        A) if ((idx > 0));    then idx=$((idx - 1)); fi ;;
                        B) if ((idx < n-1));  then idx=$((idx + 1)); fi ;;
                    esac
                else
                    return 1   # standalone ESC = back
                fi
                ;;
            k) if ((idx > 0));    then idx=$((idx - 1)); fi ;;
            j) if ((idx < n-1));  then idx=$((idx + 1)); fi ;;
            '')
                # Enter
                _res="${_val[$idx]}"
                printf "\n"
                return 0
                ;;
            q|Q)
                printf "\n"
                return 1
                ;;
        esac

        _draw
    done
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_package() {
    local prompt="$1"
    local input
    printf "  \033[1;33m%s\033[0m \033[90mpackage name(s):\033[0m " "$prompt" >&2
    read -r input
    printf "%s" "$input"
}

run_cmd() {
    printf "\n  \033[90mrunning:\033[0m lazypac %s\n  " "$*"
    printf '─%.0s' {1..50}
    printf "\n\n"
    lazypac "$@" || true
    printf "\n  \033[90mPress ENTER to continue...\033[0m"
    read -r
}

# ---------------------------------------------------------------------------
# Submenus
# ---------------------------------------------------------------------------

menu_packages() {
    local labels=("install" "remove" "purge" "update" "upgrade" "safe-upgrade" "downgrade")
    local values=("install" "remove" "purge" "update" "upgrade" "safe-upgrade" "downgrade")
    local choice

    while true; do
        _pick "Packages" labels values choice || return

        case "$choice" in
            install|remove|purge|downgrade)
                local input; local -a pkgs
                input=$(get_package "$choice")
                [[ -z "$input" ]] && continue
                read -ra pkgs <<< "$input"
                run_cmd "$choice" "${pkgs[@]}"
                ;;
            *) run_cmd "$choice" ;;
        esac
    done
}

menu_query() {
    local labels=("search" "info" "list" "installed" "check" "deps" "orphans" "check-updates" "ignore" "unignore" "ignored")
    local values=("search" "info" "list" "installed" "check" "deps" "orphans" "check-updates" "ignore" "unignore" "ignored")
    local choice

    while true; do
        _pick "Query" labels values choice || return

        case "$choice" in
            search|info|installed|check|deps|ignore|unignore)
                local input; local -a pkgs
                input=$(get_package "$choice")
                [[ -z "$input" ]] && continue
                read -ra pkgs <<< "$input"
                run_cmd "$choice" "${pkgs[@]}"
                ;;
            *) run_cmd "$choice" ;;
        esac
    done
}

menu_maintenance() {
    local labels=("remove-orphans" "cache-size" "cache-clean" "cache-clean-old" "cache-clean-all")
    local values=("remove-orphans" "cache-size" "cache-clean" "cache-clean-old" "cache-clean-all")
    local choice

    while true; do
        _pick "Maintenance" labels values choice || return
        run_cmd "$choice"
    done
}

menu_logs() {
    local labels=("log" "logclean" "pacnew")
    local values=("log" "logclean" "pacnew")
    local choice

    while true; do
        _pick "Logs & Pacnew" labels values choice || return
        run_cmd "$choice"
    done
}

# ---------------------------------------------------------------------------
# Main menu
# ---------------------------------------------------------------------------

main_menu() {
    local labels=("Packages     install / remove / upgrade …"
                  "Query        search / info / orphans …"
                  "Maintenance  cache / orphan cleanup …"
                  "Logs         log / logclean / pacnew")
    local values=("packages" "query" "maintenance" "logs")
    local choice

    while true; do
        _pick "lazypac-tui  v$VERSION" labels values choice || break

        case "$choice" in
            packages)    menu_packages ;;
            query)       menu_query ;;
            maintenance) menu_maintenance ;;
            logs)        menu_logs ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

check_deps
clear
show_banner
main_menu
printf "\n  \033[90mlazypac-tui — bye.\033[0m\n\n"
