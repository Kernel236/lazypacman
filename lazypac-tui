# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------

check_deps() {
    if ! command -v dialog &>/dev/null; then
        echo "Error: 'dialog' is required but not installed."
        echo "Install it with: lazypac install dialog"
        exit 1
    fi
    if ! command -v lazypac &>/dev/null; then
        echo "Error: 'lazypac' is not in PATH."
        echo "Install lazypac first: https://$GITHUB_URL"
        exit 1
    fi
}

