#!/usr/bin/env bash
set -uo pipefail

export VERSION="1.4.0"

# Detection order: yay > paru > pacman
if command -v yay &>/dev/null; then
    PKG=yay
elif command -v paru &>/dev/null; then
    PKG=paru
elif command -v pacman &>/dev/null; then
    PKG=pacman
else
    echo "No package manager found."
    exit 1
fi

# yay and paru handle privilege escalation themselves.
# Plain pacman needs sudo for any operation that writes to the system.
pkg_write() {
    if [[ "$PKG" == "pacman" ]]; then
        sudo pacman "$@"
    else
        "$PKG" "$@"
    fi
}

# Label used in help output to show what actually runs
if [[ "$PKG" == "pacman" ]]; then
    export PKG_W="sudo pacman"
else
    export PKG_W="$PKG"
fi

_LAZYPAC_LIB="${_LAZYPAC_LIB:-/usr/lib/lazypac}"
export LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/lazypac"
mkdir -p "$LOG_DIR"

# shellcheck source=lib/help.sh
source "$_LAZYPAC_LIB/help.sh"     || exit 1
# shellcheck source=lib/config.sh
source "$_LAZYPAC_LIB/config.sh"   || exit 1
# shellcheck source=lib/packages.sh
source "$_LAZYPAC_LIB/packages.sh" || exit 1
# shellcheck source=lib/cache.sh
source "$_LAZYPAC_LIB/cache.sh"    || exit 1
# shellcheck source=lib/query.sh
source "$_LAZYPAC_LIB/query.sh"    || exit 1
# shellcheck source=lib/logs.sh
source "$_LAZYPAC_LIB/logs.sh"     || exit 1

main() {
    local cmd="${1:-}"
    shift || true
    case "$cmd" in
        install)         cmd_install "$@" ;;
        remove)          cmd_remove "$@" ;;
        purge)           cmd_purge "$@" ;;
        update)          cmd_update "$@" ;;
        upgrade)         cmd_upgrade "$@" ;;
        downgrade)       cmd_downgrade "$@" ;;
        remove-orphans)  cmd_remove_orphans "$@" ;;
        safe-upgrade)    cmd_safe_upgrade "$@" ;;
        ignore)          cmd_ignore "$@" ;;
        unignore)        cmd_unignore "$@" ;;
        ignored)         cmd_ignored "$@" ;;
        search)          cmd_search "$@" ;;
        info)            cmd_info "$@" ;;
        list)            cmd_list "$@" ;;
        installed)       cmd_installed "$@" ;;
        check)           cmd_check "$@" ;;
        deps)            cmd_deps "$@" ;;
        orphans)         cmd_orphans "$@" ;;
        check-updates)   cmd_check_updates "$@" ;;
        cache-clean)     cmd_cache_clean "$@" ;;
        cache-clean-all) cmd_cache_clean_all "$@" ;;
        cache-clean-old) cmd_cache_clean_old "$@" ;;
        cache-size)      cmd_cache_size "$@" ;;
        log)             cmd_log "$@" ;;
        logclean)        cmd_logclean "$@" ;;
        pacnew)          cmd_pacnew "$@" ;;
        version|--version|-v)
            echo "lazypac $VERSION"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        "")
            echo "Unknown command. Run 'lazypac help'."
            exit 1
            ;;
        *)
            echo "Unknown command: '$cmd'"
            echo "Run 'lazypac help' to see available commands."
            exit 1
            ;;
    esac
}

main "$@"
