#!/usr/bin/env bash
set -uo pipefail

VERSION="1.1.0"

# Detection order: yay > paru > pacman
if command -v yay &>/dev/null; then
    PKG=yay
elif command -v paru &>/dev/null; then
    PKG=paru
elif command -v pacman &>/dev/null; then
    PKG=pacman
else
    echo "No package manager found."
    exit 1
fi

# yay and paru handle privilege escalation themselves.
# Plain pacman needs sudo for any operation that writes to the system.
pkg_write() {
    if [[ "$PKG" == "pacman" ]]; then
        sudo pacman "$@"
    else
        "$PKG" "$@"
    fi
}

# Label used in help output to show what actually runs
if [[ "$PKG" == "pacman" ]]; then
    PKG_W="sudo pacman"
else
    PKG_W="$PKG"
fi

LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/lazypac"
mkdir -p "$LOG_DIR"

cmd="${1:-}"

case "$cmd" in
    install)
        [[ -z "${2:-}" ]] && { echo "Usage: lazypac install <package...>"; exit 1; }
        pkg_write -S "${@:2}"
        ;;
    remove)
        [[ -z "${2:-}" ]] && { echo "Usage: lazypac remove <package...>"; exit 1; }
        pkg_write -Rs "${@:2}"
        ;;
    purge)
        [[ -z "${2:-}" ]] && { echo "Usage: lazypac purge <package...>"; exit 1; }
        pkg_write -Rns "${@:2}"
        ;;
    update)
        pkg_write -Sy
        ;;
    upgrade)
        pkg_write -Syu "${@:2}"
        ;;
    safe-upgrade)
        timestamp=$(date +"%Y%m%d_%H%M%S")
        before_snap=$(mktemp /tmp/lazypac_before_XXXXXX)
        after_snap=$(mktemp /tmp/lazypac_after_XXXXXX)
        log_file="${LOG_DIR}/upgrade_${timestamp}.log"

        trap 'rm -f "$before_snap" "$after_snap"' EXIT

        echo "==> Snapshotting installed packages..."
        "$PKG" -Q > "$before_snap"

        echo "==> Running upgrade..."
        pkg_write -Syu "${@:2}"

        echo ""
        echo "==> Snapshotting new state..."
        "$PKG" -Q > "$after_snap"

        echo "==> Generating upgrade log..."
        {
            echo "Lazy Pacman — upgrade log"
            echo "Date: $(date)"
            echo "Package manager: $PKG"
            echo ""
            changed=0
            while IFS=' ' read -r p new_ver; do
                old_ver=$(awk -v name="$p" '$1==name{print $2}' "$before_snap")
                if [[ -z "$old_ver" ]]; then
                    printf "  %-40s (new install)  %s\n" "$p" "$new_ver"
                    changed=1
                elif [[ "$old_ver" != "$new_ver" ]]; then
                    printf "  %-40s %s  ->  %s\n" "$p" "$old_ver" "$new_ver"
                    changed=1
                fi
            done < "$after_snap"
            if [[ "$changed" -eq 0 ]]; then
                echo "  Nothing was updated."
            fi
        } | tee "$log_file"

        echo ""
        echo "Log saved to: $log_file"

        pacnew_found=$(find /etc \( -name "*.pacnew" -o -name "*.pacsave" \) 2>/dev/null)
        if [[ -n "$pacnew_found" ]]; then
            echo ""
            echo "==> .pacnew/.pacsave files found — review them with:"
            echo "      sudo pacdiff"
            echo ""
            echo "$pacnew_found"
        fi
        ;;
    search)
        [[ -z "${2:-}" ]] && { echo "Usage: lazypac search <term>"; exit 1; }
        "$PKG" -Ss "${@:2}"
        ;;
    info)
        [[ -z "${2:-}" ]] && { echo "Usage: lazypac info <package>"; exit 1; }
        "$PKG" -Si "${@:2}"
        ;;
    list)
        "$PKG" -Qq
        ;;
    installed)
        "$PKG" -Q
        ;;
    check)
        [[ -z "${2:-}" ]] && { echo "Usage: lazypac check <package...>"; exit 1; }
        for pkgname in "${@:2}"; do
            if "$PKG" -Q "$pkgname" &>/dev/null; then
                echo "$pkgname: installed"
            else
                echo "$pkgname: not installed"
            fi
        done
        ;;
    deps)
        [[ -z "${2:-}" ]] && { echo "Usage: lazypac deps <package>"; exit 1; }
        if ! command -v pactree &>/dev/null; then
            echo "pactree not found — install pacman-contrib"
            exit 1
        fi
        pactree "${@:2}"
        ;;
    orphans)
        if ! "$PKG" -Qdt 2>/dev/null; then
            echo "No orphan packages."
        fi
        ;;
    remove-orphans)
        mapfile -t orphan_list < <("$PKG" -Qdtq 2>/dev/null)
        if [[ ${#orphan_list[@]} -eq 0 ]]; then
            echo "No orphan packages found."
        else
            pkg_write -Rns "${orphan_list[@]}"
        fi
        ;;
    pacnew)
        echo "Searching for .pacnew and .pacsave files..."
        found=$(find /etc \( -name "*.pacnew" -o -name "*.pacsave" \) 2>/dev/null)
        if [[ -z "$found" ]]; then
            echo "No .pacnew or .pacsave files found."
        else
            echo "$found"
            echo ""
            echo "To review and merge them: sudo pacdiff"
        fi
        ;;
    log)
        if [[ -z "${2:-}" ]]; then
            if [[ -z "$(ls -A "$LOG_DIR" 2>/dev/null)" ]]; then
                echo "No logs yet. Run 'lazypac safe-upgrade' to start logging."
            else
                ls -lh "$LOG_DIR"
            fi
        else
            log_path="${LOG_DIR}/${2}"
            if [[ ! -f "$log_path" ]]; then
                echo "Log file not found: ${2}"
                echo "Run 'lazypac log' to list available logs."
                exit 1
            fi
            less "$log_path"
        fi
        ;;
    logclean)
        count=$(find "$LOG_DIR" -name "*.log" 2>/dev/null | wc -l)
        if [[ "$count" -eq 0 ]]; then
            echo "No log files to remove."
        else
            echo "Removing $count log file(s) from $LOG_DIR..."
            find "$LOG_DIR" -name "*.log" -delete
            echo "Done."
        fi
        ;;
    clean)
        pkg_write -Sc "${@:2}"
        ;;
    clean-all)
        pkg_write -Scc "${@:2}"
        ;;
    version|--version|-v)
        echo "lazypac $VERSION"
        ;;
    help|--help|-h)
        echo "Lazy Pacman $VERSION — command reference"
        echo ""
        echo "  Package management"
        printf "  %-22s %-34s %s\n" "install <pkg...>"   "Install one or more packages"       "-> $PKG_W -S <pkg...>"
        printf "  %-22s %-34s %s\n" "remove <pkg...>"    "Remove package + orphan deps"        "-> $PKG_W -Rs <pkg...>"
        printf "  %-22s %-34s %s\n" "purge <pkg...>"     "Remove package + config files"       "-> $PKG_W -Rns <pkg...>"
        printf "  %-22s %-34s %s\n" "update"             "Sync repositories"                   "-> $PKG_W -Sy"
        printf "  %-22s %-34s %s\n" "upgrade"            "Upgrade all packages"                "-> $PKG_W -Syu"
        printf "  %-22s %-34s %s\n" "safe-upgrade"       "Upgrade + log + pacnew check"        "-> $PKG_W -Syu + log"
        echo ""
        echo "  Query"
        printf "  %-22s %-34s %s\n" "search <term>"      "Search for a package"                "-> $PKG -Ss <term>"
        printf "  %-22s %-34s %s\n" "info <pkg>"         "Show package details"                "-> $PKG -Si <pkg>"
        printf "  %-22s %-34s %s\n" "list"               "List installed (names only)"         "-> $PKG -Qq"
        printf "  %-22s %-34s %s\n" "installed"          "List installed (names+versions)"     "-> $PKG -Q"
        printf "  %-22s %-34s %s\n" "check <pkg...>"     "Check if package(s) are installed"  "-> $PKG -Q <pkg>"
        printf "  %-22s %-34s %s\n" "deps <pkg>"         "Show package dependency tree"        "-> pactree <pkg>"
        printf "  %-22s %-34s %s\n" "orphans"            "List orphan packages"                "-> $PKG -Qdt"
        echo ""
        echo "  Pacnew / pacsave"
        printf "  %-22s %-34s %s\n" "pacnew"             "Find .pacnew/.pacsave files"         "-> find /etc -name *.pacnew"
        echo ""
        echo "  Logs"
        printf "  %-22s %-34s %s\n" "log"                "List upgrade logs"                   "-> ls $LOG_DIR"
        printf "  %-22s %-34s %s\n" "log <file>"         "Read a log file"                     "-> less $LOG_DIR/<file>"
        printf "  %-22s %-34s %s\n" "logclean"           "Remove all upgrade logs"             "-> rm $LOG_DIR/*.log"
        echo ""
        echo "  Cleanup"
        printf "  %-22s %-34s %s\n" "remove-orphans"     "Remove all orphan packages"          "-> $PKG_W -Rns \$($PKG -Qdtq)"
        printf "  %-22s %-34s %s\n" "clean"              "Remove old cached packages"          "-> $PKG_W -Sc"
        printf "  %-22s %-34s %s\n" "clean-all"          "Remove all cached packages"          "-> $PKG_W -Scc"
        echo ""
        echo "Tip: multiple packages and extra flags are passed through directly."
        echo "     lazypac install firefox chromium --noconfirm"
        echo "     lazypac upgrade --devel"
        ;;
    "")
        echo "Unknown command. Run 'lazypac help'."
        exit 1
        ;;
    *)
        echo "Unknown command: '$cmd'"
        echo "Run 'lazypac help' to see available commands."
        exit 1
        ;;
esac
